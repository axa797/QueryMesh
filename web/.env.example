# QueryMesh FastAPI (browser calls this origin — set CORS on the API).
NEXT_PUBLIC_QUERYMESH_URL=http://127.0.0.1:8000

# Browser links to Langfuse traces from the Eval dashboard (region/host must match the project).
# EU default: https://cloud.langfuse.com   US data region: https://us.cloud.langfuse.com
NEXT_PUBLIC_LANGFUSE_PUBLIC_URL=https://cloud.langfuse.com
#
# Needed only when the API returns a bare trace id (reports created before persisted URLs).
# Project id appears in Langfuse URLs: .../project/<this-part>/traces/...
NEXT_PUBLIC_LANGFUSE_PROJECT_ID=
