# querymesh — copy to .env and adjust. Local flow: docs/local_dev.md · scripts/prepare_local.sh
#
# --- GCP / Vertex AI (primary region us-central1) ---
# Application Default Credentials: gcloud auth application-default login (no service account JSON in repo).
# For heuristic-only local mode (no Vertex), leave GOOGLE_CLOUD_PROJECT empty.
GOOGLE_CLOUD_PROJECT=querymesh-kb
GOOGLE_CLOUD_LOCATION=us-central1

# Optional overrides (defaults can live in code)
# VERTEX_LLM_MODEL=gemini-2.5-flash
# VERTEX_LLM_MODEL=gemini-2.0-flash-001
# VERTEX_EMBEDDING_MODEL=text-embedding-005

# --- Qdrant (vector store; local: docker-compose) ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=gcp_docs
# QDRANT_API_KEY=

# --- Redis (session envelope + slowapi rate-limit storage; local: docker-compose) ---
REDIS_URL=redis://localhost:6379/0

# --- Rate limiting (Phase 14): QUERY_RATE_LIMIT applies before auth on matching routes. ---
# RATE_LIMIT_STORAGE_URI defaults to REDIS_URL if unset (use memory:// in tests via conftest).
# QUERY_RATE_LIMIT=60/minute

# --- Postgres (users, api_keys, user_memory, LangGraph checkpointer) ---
# Local: postgres service in infra/docker-compose.yml (user postgres / db querymesh).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/querymesh
# Cloud SQL example: postgresql+asyncpg://user:pass@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE

# --- Ingestion API (Phase 15): document directory for POST /ingest { "source": "gcp_docs" } ---
# Public GCP PDFs only; directory is gitignored (see corpus/).
INGESTION_GCP_DOCS_DIR=./corpus/gcp_docs
# Set true once when switching embedding models or fixing collection dimensions.
# INGESTION_RECREATE_COLLECTION=true

# --- BigQuery (analytics agent; seeded via scripts/bootstrap_bq.py) ---
BIGQUERY_PROJECT_ID=querymesh-kb
BIGQUERY_DATASET=querymesh
# BIGQUERY_LOCATION=US

# --- Auth (API keys stored as HMAC-SHA256(key, pepper); same value as Secret Manager in prod) ---
API_KEY_PEPPER=generate-a-long-random-secret

# --- E2B (code execution sandbox; from Secret Manager in prod) ---
E2B_API_KEY=
# Template ID from `e2b template build` (see scripts/README.md).
# E2B_TEMPLATE_ID=querymesh-code

# --- Langfuse (hosted SaaS; §11). Optional locally — enables graph + LLM spans when set. ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
# LANGFUSE_TRACING_ENVIRONMENT=staging

# --- Account portal (optional): POST /account/register and /account/login use a JWT (not for /query).
# Mint API keys with POST /account/api-keys using Authorization: Bearer <portal_jwt>.
# PORTAL_JWT_SECRET=generate-a-long-random-string
# PORTAL_JWT_TTL_HOURS=168

# --- Browser demo (demo/querymesh-demo.html): allow browser origin to call /query ---
# Recommend * for local only; restrict in production.
# CORS_ALLOW_ORIGINS=*

# --- Feature flags (spec: RAG_VERTEX_RERANK — requires Discovery Engine API on the GCP project) ---
RAG_VERTEX_RERANK=true
# When rerank is on: Qdrant prefetch size before semantic rank (default 20; max 50 in code).
# RAG_RERANK_CANDIDATE_LIMIT=20
# Discovery Engine ranking model (enable Discovery Engine API on the GCP project).
# VERTEX_RANKING_MODEL=semantic-ranker-fast-004

# --- Eval harness (Phase 17): RAGAS judge; not required for API/tests ---
# Install optional deps: uv sync --group eval
# RUN_EVAL=1 enables the RAGAS runner (needs GOOGLE_CLOUD_PROJECT + ADC).
#
# Recommended workflow (after corpus is indexed):
#   1. PYTHONPATH=. uv run python evals/harvest.py  → evals/harvested_dataset.json
#   2. RUN_EVAL=1 PYTHONPATH=. uv run --group eval python -m evals.ragas_eval --harvested [--limit N]
#      Scores upload automatically to Langfuse when LANGFUSE_PUBLIC_KEY/SECRET_KEY are set.
#
# Without --harvested, ragas_eval uses static contexts from golden_dataset.json (smoke-test only).
