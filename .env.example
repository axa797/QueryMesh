# --- GCP / Vertex AI (primary region us-central1) ---
# Use Application Default Credentials only: gcloud auth application-default login
# Do not use GOOGLE_APPLICATION_CREDENTIALS or committed service account JSON.
GOOGLE_CLOUD_PROJECT=querymesh-kb
GOOGLE_CLOUD_LOCATION=us-central1

# Optional overrides (defaults can live in code)
# VERTEX_LLM_MODEL=gemini-2.0-flash
# VERTEX_LLM_MODEL=gemini-2.5-pro
# VERTEX_EMBEDDING_MODEL=text-embedding-004

# --- Qdrant (vector store; local: docker-compose) ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=gcp_docs
# QDRANT_API_KEY=

# --- Redis (session envelope + slowapi rate limit storage; local: docker-compose) ---
REDIS_URL=redis://localhost:6379/0

# --- Postgres (users, api_keys, user_memory, LangGraph checkpointer) ---
# Local: postgres service in infra/docker-compose.yml (user postgres / db querymesh).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/querymesh
# Cloud SQL example: postgresql+asyncpg://user:pass@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE

# --- BigQuery (analytics agent; seeded via scripts/bootstrap_bq.py) ---
BIGQUERY_PROJECT_ID=querymesh-kb
BIGQUERY_DATASET=querymesh
# BIGQUERY_LOCATION=US

# --- Auth (API keys stored as HMAC-SHA256(key, pepper); same value as Secret Manager in prod) ---
API_KEY_PEPPER=generate-a-long-random-secret

# --- E2B (code execution sandbox; from Secret Manager in prod) ---
E2B_API_KEY=
# Template ID from `e2b template build` (see scripts/README.md).
# E2B_TEMPLATE_ID=querymesh-code

# --- Langfuse (hosted SaaS; §11). Optional locally — enables graph + LLM spans when set. ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# --- Feature flags (spec: RAG_VERTEX_RERANK — on in prod, off locally) ---
RAG_VERTEX_RERANK=false
