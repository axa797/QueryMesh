# Copy to terraform.tfvars and fill in. This file is gitignored.
# Secret values (passwords, API keys) are NOT stored here — they live in
# Secret Manager, created by scripts/bootstrap_gcp.sh.

project_id = "querymesh-kb"
region     = "us-central1"

