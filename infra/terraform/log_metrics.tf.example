# Copy into a Terraform root that already configures the Google provider.
# Set variable project_id (or replace with literal project = "my-project").

variable "project_id" {
  type        = string
  description = "GCP project that owns Cloud Run + Logging"
}

variable "cloud_run_service_name" {
  type        = string
  default     = "api"
  description = "Cloud Run service name emitting /query logs"
}

# Increments once per matching log line (each /query that emitted querymesh_query).
resource "google_logging_metric" "querymesh_query_requests" {
  project = var.project_id
  name    = "querymesh_query_requests"
  filter  = <<-EOT
    resource.type="cloud_run_revision"
    resource.labels.service_name="${var.cloud_run_service_name}"
    (
      jsonPayload.message_type="querymesh_query"
      OR textPayload=~"\"message_type\"\\s*:\\s*\"querymesh_query\""
    )
  EOT

  metric_descriptor {
    metric_kind  = "DELTA"
    value_type   = "INT64"
    display_name = "querymesh POST /query (log lines)"
    description  = "Delta count of querymesh_query structured lines; add latency/error metrics in Console if needed"
  }
}
