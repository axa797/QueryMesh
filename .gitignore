# Secrets / credentials — never commit
.env
.env.*
!.env.example
*.pem
*.p12
*.key
service_account*.json
application_default_credentials.json

# Python
.venv/
__pycache__/
*.py[cod]
*$py.class
.Python
.pytest_cache/
.ruff_cache/
dist/
build/
*.egg-info/

# Editor / OS
.idea/
.vscode/
.DS_Store
*.swp
*.swo

# Python cache (belt-and-suspenders; uv/pytest generate these locally)
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Next.js build output and dependencies
web/.next/
web/node_modules/

# Terraform — state and variable files contain secrets
infra/terraform/terraform.tfvars
infra/terraform/.terraform/
infra/terraform/.terraform.lock.hcl
infra/terraform/*.tfstate
infra/terraform/*.tfstate.backup
infra/terraform/*.tfplan

# Local GCP documentation PDFs (corpus; not committed)
corpus/

# Harvested eval data (runtime output; regenerate with evals/harvest.py)
evals/harvested_dataset.json

# Next.js generated types (regenerate via `next dev` / `next build` in web/)
web/next-env.d.ts
